# Node.js version
export NODE_VERSION=24.14.1

# Yarn version
export YARN_VERSION=4.9.1

# Database configuration (Supabase Postgres via 1Password)
export DATABASE_URL="$(op read 'op://Eureka/Supabase Database/connection-string')"

# Development environment
export NODE_ENV=development
export NEXT_TELEMETRY_DISABLED=1

# Allow .envrc
export DIRENV_ALLOW=true
